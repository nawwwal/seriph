# Copy to .env.local and fill in. Never commit real values.

# Firebase Admin (server / API routes)
FIREBASE_ADMIN_CLIENT_EMAIL=
FIREBASE_ADMIN_PRIVATE_KEY=
FIREBASE_ADMIN_PROJECT_ID=
FIREBASE_STORAGE_BUCKET=

# Firebase client (safe to expose in the browser; restrict keys in GCP console)
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_APP_ID=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_MEASUREMENT_ID=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=

# Optional
UPLOAD_SECRET_TOKEN=
NEXT_PUBLIC_ENABLE_REACT_GRAB=false
VERCEL_OIDC_TOKEN=

# Cloud Functions local (functions/.env.local)
# GOOGLE_APPLICATION_CREDENTIALS=/absolute/path/to/service-account.json
# GOOGLE_CLOUD_LOCATION=asia-southeast1
# GEMINI_WEB_SEARCH_ENABLED=
# GEMINI_FALLBACK_MODEL=
# MAX_CONCURRENT_AI_OPS=
