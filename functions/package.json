{
    "name": "functions",
    "scripts": {
        "build": "tsc",
        "serve": "npm run build && firebase emulators:start --only functions",
        "shell": "npm run build && firebase functions:shell",
        "start": "npm run shell",
        "deploy": "firebase deploy --only functions",
        "logs": "firebase functions:log",
        "lint": "tsc --noEmit",
        "test": "vitest run",
        "backfill:search": "npm run build && node lib/scripts/backfillSearchVectors.js",
        "backfill:catalog-summary": "npm run build && node lib/scripts/backfillCatalogSummaries.js",
        "auth:set-password": "npm run build && node lib/scripts/setAuthPassword.js",
        "auth:beta-allowlist": "npm run build && node lib/scripts/manageBetaAllowlist.js",
        "migrate:old-schema-fonts": "npm run build && node lib/scripts/migrateOldSchemaFonts.js",
        "migrate:historical-imports": "npm run build && node lib/scripts/migrateHistoricalImports.js",
        "merge:split-families": "npm run build && node lib/scripts/mergeSplitFamilies.js",
        "reconcile:import-pipeline": "npm run build && node lib/scripts/reconcileImportPipeline.js"
    },
    "engines": {
        "node": "22"
    },
    "main": "lib/index.js",
    "dependencies": {
        "@google-cloud/aiplatform": "^6.10.0",
        "@google-cloud/tasks": "^6.2.3",
        "@google-cloud/vertexai": "^1.12.0",
        "@google/genai": "^2.13.0",
        "@napi-rs/canvas": "^1.0.2",
        "firebase-admin": "^14.2.0",
        "firebase-functions": "^7.3.0",
        "fontkit": "^2.0.4",
        "google-auth-library": "^10.9.0",
        "opentype.js": "^2.0.0",
        "unzipper": "^0.12.5",
        "uuid": "^14.0.1",
        "wawoff2": "^2.0.1"
    },
    "devDependencies": {
        "@types/fontkit": "^2.0.9",
        "@types/opentype.js": "^1.3.10",
        "@types/unzipper": "^0.10.11",
        "typescript": "^6.0.3",
        "vitest": "^4.1.10"
    },
    "overrides": {
        "@grpc/grpc-js": "1.14.4",
        "@types/request": {
            "form-data": "2.5.6"
        },
        "fast-xml-parser": "5.10.1",
        "firebase-functions": {
            "express": "4.22.2"
        },
        "firebase-admin": {
            "jsonwebtoken": "9.0.3"
        },
        "gaxios": {
            "uuid": "11.1.1"
        },
        "google-auth-library": {
            "jws": "4.0.1"
        },
        "gtoken": {
            "jws": "4.0.1"
        },
        "path-to-regexp": "0.1.13",
        "protobufjs": "7.6.5",
        "retry-request": "8.0.3",
        "teeny-request": "10.1.3"
    },
    "packageManager": "npm@11.8.0",
    "private": true
}
